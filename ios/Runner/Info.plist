<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>$(DEVELOPMENT_LANGUAGE)</string>
	<key>CFBundleDisplayName</key>
	<string>Musly</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>musly</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(FLUTTER_BUILD_NAME)</string>
	<key>CFBundleSignature</key>
	<string>????</string>
	<key>CFBundleVersion</key>
	<string>$(FLUTTER_BUILD_NUMBER)</string>
	<key>LSRequiresIPhoneOS</key>
	<true/>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>
	<key>UIMainStoryboardFile</key>
	<string>Main</string>
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>UISupportedInterfaceOrientations~ipad</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationPortraitUpsideDown</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<key>CADisableMinimumFrameDurationOnPhone</key>
	<true/>
	<key>UIApplicationSupportsIndirectInputEvents</key>
	<true/>

	<!-- Google Cast Support -->
	<key>NSLocalNetworkUsageDescription</key>
	<string>Musly uses the local network to discover and connect to Google Cast devices.</string>
	<key>NSBonjourServices</key>
	<array>
		<string>_googlecast._tcp</string>
		<string>_CC1AD845._googlecast._tcp</string>
	</array>
	
	<!-- Background Modes for Audio Playback -->
	<key>UIBackgroundModes</key>
	<array>
		<string>audio</string>
		<string>fetch</string>
		<string>remote-notification</string>
	</array>
	
	<!-- CarPlay Support TEMPORARILY DISABLED (requires approved entitlement)
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
		<key>UISceneConfigurations</key>
		<dict>
			<key>CPTemplateApplicationSceneSessionRoleApplication</key>
			<array>
				<dict>
					<key>UISceneClassName</key>
					<string>CPTemplateApplicationScene</string>
					<key>UISceneConfigurationName</key>
					<string>CarPlay Configuration</string>
					<key>UISceneDelegateClassName</key>
					<string>$(PRODUCT_MODULE_NAME).CarPlaySceneDelegate</string>
				</dict>
			</array>
		</dict>
	</dict>
	-->
	<key>UIRequiredDeviceCapabilities</key>
	<array>
		<string>arm64</string>
	</array>
	
	<!-- Audio Session Category -->
	<key>AVAudioSessionCategory</key>
	<string>AVAudioSessionCategoryPlayback</string>
	
	<!-- Allow playback while locked -->
	<key>UIBackgroundTaskIdentifier</key>
	<string>audio</string>
	
	<!-- Bluetooth Permissions (iOS 13+) -->
	<key>NSBluetoothAlwaysUsageDescription</key>
	<string>Musly uses Bluetooth to send song information and album artwork to your connected audio devices (car stereo, headphones, speakers).</string>
	<key>NSBluetoothPeripheralUsageDescription</key>
	<string>Musly uses Bluetooth to connect to audio devices and display current playing music information.</string>
	
	<!-- Network Usage -->
	<key>NSAppTransportSecurity</key>
	<dict>
		<key>NSAllowsArbitraryLoads</key>
		<true/>
	</dict>

	<!-- Media Library / Music -->
	<key>NSAppleMusicUsageDescription</key>
	<string>Musly needs access to your music library to browse and play your songs.</string>

	<!-- Photo Library (album artwork import) -->
	<key>NSPhotoLibraryUsageDescription</key>
	<string>Musly needs access to your photo library to set custom album artwork.</string>
	<key>NSPhotoLibraryAddUsageDescription</key>
	<string>Musly needs permission to save album artwork to your photo library.</string>

	<!-- File access via Files app / iCloud Drive -->
	<key>NSDocumentsFolderUsageDescription</key>
	<string>Musly needs access to your files to import local music tracks.</string>
	<key>UIFileSharingEnabled</key>
	<true/>
	<key>LSSupportsOpeningDocumentsInPlace</key>
	<true/>

	<!-- Microphone (required by some audio APIs) -->
	<key>NSMicrophoneUsageDescription</key>
	<string>Musly requires microphone access for certain audio features.</string>
</dict>
</plist>
